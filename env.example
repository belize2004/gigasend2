# App URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Pexels API
NEXT_PUBLIC_PEXELS_API_KEY="your-pexels-api-key"

# Resend API
RESEND_API_KEY="your-resend-api-key"
ADMIN_EMAILS="admin@example.com,second-admin@example.com"
PUBLIC_SENTRY_DSN="https://public-key@o000000.ingest.sentry.io/000000"
PUBLIC_SENTRY_ENVIRONMENT="production"
PUBLIC_SENTRY_RELEASE="optional-release-sha"
SENTRY_AUTH_TOKEN="optional-source-map-upload-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="gigasend"
PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0"
PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="1"

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID="your-cloudflare-r2-account-id"
R2_ACCESS_KEY_ID="your-cloudflare-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-cloudflare-r2-secret-access-key"
R2_BUCKET_NAME="your-r2-bucket-name"

# Sanity

# Cloudflare D1
# Create with: npx wrangler d1 create gigasend
# Apply locally: npx wrangler d1 migrations apply gigasend --local
# Apply remote: npx wrangler d1 migrations apply gigasend --remote
D1_DATABASE_NAME="gigasend"

# Auth
JWT_SECRET="your-jwt-secret"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"
