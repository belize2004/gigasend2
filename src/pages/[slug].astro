---
import BaseLayout from "../layouts/BaseLayout.astro";
import { seoLandingPages } from "../data/seoLandingPages";

export const prerender = true;

export function getStaticPaths() {
  return seoLandingPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page: landingPage } = Astro.props;
const canonical = `https://www.gigasend.us/${landingPage.slug}`;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: landingPage.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<BaseLayout title={landingPage.title} description={landingPage.metaDescription} canonical={canonical}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <main class="min-h-screen bg-slate-50 text-slate-950">
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Primary">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-slate-950">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-600 text-white">↑</span>
          GigaSend
        </a>
        <div class="hidden items-center gap-6 text-sm font-medium text-slate-700 sm:flex">
          <a class="hover:text-blue-700" href="/transfer/">Transfer</a>
          <a class="hover:text-blue-700" href="/plans/">Plans</a>
          <a class="hover:text-blue-700" href="/send-large-files-free/">Free transfer</a>
        </div>
      </nav>
    </header>

    <section class="bg-white">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-20">
        <div>
          <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-blue-700">{landingPage.eyebrow}</p>
          <h1 class="max-w-4xl text-4xl font-bold leading-tight text-slate-950 sm:text-5xl">{landingPage.h1}</h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">{landingPage.intro}</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="/transfer/" class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-blue-700">
              {landingPage.cta}
            </a>
            <a href="/plans/" class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-6 py-3 text-base font-semibold text-slate-800 hover:border-blue-500 hover:text-blue-700">
              View plans
            </a>
          </div>
          <div class="mt-8 grid max-w-2xl grid-cols-3 gap-3 text-center text-sm">
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
              <div class="text-xl font-bold text-slate-950">10GB</div>
              <div class="mt-1 text-slate-600">Free transfers</div>
            </div>
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
              <div class="text-xl font-bold text-slate-950">3 days</div>
              <div class="mt-1 text-slate-600">Free storage</div>
            </div>
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
              <div class="text-xl font-bold text-slate-950">5TB</div>
              <div class="mt-1 text-slate-600">Enterprise</div>
            </div>
          </div>
        </div>

        <aside class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
          <h2 class="text-xl font-bold text-slate-950">How it works</h2>
          <ol class="mt-6 space-y-4">
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">1</span>
              <span><strong>Upload</strong> your large file, folder, zip, or video.</span>
            </li>
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">2</span>
              <span><strong>Add</strong> a recipient and optional message.</span>
            </li>
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">3</span>
              <span><strong>Send</strong> a secure download link instead of an attachment.</span>
            </li>
          </ol>
        </aside>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-3">
        {landingPage.sections.map((section) => (
          <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-xl font-bold text-slate-950">{section.heading}</h2>
            <p class="mt-3 leading-7 text-slate-600">{section.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="bg-white py-14">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-slate-950">Compare your options</h2>
        <div class="mt-8 overflow-hidden rounded-xl border border-slate-200">
          <table class="w-full border-collapse text-left text-sm">
            <thead class="bg-slate-100 text-slate-800">
              <tr>
                <th class="p-4 font-semibold">Method</th>
                <th class="p-4 font-semibold">Best for</th>
                <th class="p-4 font-semibold">Limitation</th>
                <th class="p-4 font-semibold">GigaSend angle</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              {landingPage.comparison.map((row) => (
                <tr>
                  <td class="p-4 font-semibold text-slate-950">{row.method}</td>
                  <td class="p-4 text-slate-600">{row.bestFor}</td>
                  <td class="p-4 text-slate-600">{row.limitation}</td>
                  <td class="p-4 text-slate-600">{row.gigaSendAngle}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-7xl gap-8 px-4 py-14 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
      <div>
        <h2 class="text-3xl font-bold text-slate-950">Why this page is different</h2>
        <p class="mt-4 leading-7 text-slate-600">{landingPage.differentiation}</p>
        <a href="/transfer/" class="mt-6 inline-flex rounded-lg bg-blue-600 px-5 py-3 font-semibold text-white hover:bg-blue-700">{landingPage.cta}</a>
      </div>

      <div>
        <h2 class="text-3xl font-bold text-slate-950">FAQ</h2>
        <div class="mt-6 space-y-4">
          {landingPage.faqs.map((faq) => (
            <details class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
              <summary class="cursor-pointer font-semibold text-slate-950">{faq.question}</summary>
              <p class="mt-3 leading-7 text-slate-600">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-white py-12">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-slate-950">Related large file transfer guides</h2>
        <div class="mt-6 flex flex-wrap gap-3">
          {landingPage.internalLinks.map((link) => (
            <a class="rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:border-blue-500 hover:text-blue-700" href={link.href}>
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-blue-600 py-14 text-white">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold">Ready to send a large file?</h2>
        <p class="mt-4 text-lg text-blue-100">Upload your file and send a secure download link in a few clicks.</p>
        <a href="/transfer/" class="mt-8 inline-flex rounded-lg bg-white px-6 py-3 font-semibold text-blue-700 hover:bg-blue-50">{landingPage.cta}</a>
      </div>
    </section>
  </main>
</BaseLayout>
